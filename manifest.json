{
  "manifest_version": 3,
  "name": "Tab Garden",
  "version": "2.0.0",
  "description": "Your tabs and bookmarks growing in one place. Grouped by domain, themed to match Chrome, close with style.",
  "permissions": ["tabs", "activeTab", "bookmarks", "storage"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Garden",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
